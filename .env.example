# NYC VC Deal Scraper — Environment Variables
# All keys are OPTIONAL. Missing keys gracefully skip that feature.

# ── LLM Extraction (Claude Haiku) ──
# Used for structured deal extraction from article text
# Free tier: pay-per-use via Anthropic Console
ANTHROPIC_API_KEY=

# ── Google Custom Search ──
# Used to find company websites for deals missing one
# Free tier: 100 queries/day
# Setup: https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ── Apollo.io Org Enrichment ──
# Enriches deals with employee count, description, logo, LinkedIn
# Free tier: 100 credits/month
APOLLO_API_KEY=

# ── Clearbit / HubSpot Enrichment ──
# Alternative enrichment: tech stack, revenue estimates
# Free tier: 50 lookups/month
CLEARBIT_API_KEY=

# ── Hunter.io Domain Validation ──
# Validates company domains found by Google CSE
# Free tier: 25 lookups/month
HUNTER_API_KEY=

# ── Crunchbase Basic API ──
# High-quality funding round data
# Free tier: 200 requests/day (requires application)
CRUNCHBASE_API_KEY=

# ── OpenCorporates ──
# Company registration data (optional — public endpoint works at lower rate)
OPENCORPORATES_API_KEY=

# ── Flask Web App ──
# Secret key for session encryption (auto-generated on Render)
SECRET_KEY=change-me-in-production

# ── Database ──
# SQLite path (defaults to ./nyc_vc_deals.db)
# DATABASE_PATH=./nyc_vc_deals.db
